---
import Header from "../components/Header.astro";
import "../styles/global.css";

const { backgroundImage = "/images/waves_background.jpg" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${base}/Super8-circle.png`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link href="https://fonts.googleapis.com/css2?family=Frijole&family=Nunito&family=Orbitron&family=Play:wght@400;700&family=Quicksand:wght@400;700&family=VT323&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <title>Dario's Blog</title>
  </head>
  <body>
    <Header />
    <main style={`background-image: url('${backgroundImage}')`}>
      <slot />
    </main>
  </body>
</html>

<style define:vars={{
    cursorNormal: `url('${base}/images/cursor2.gif'), auto`,
    cursorHover: `url('${base}/images/iron-ingot.png'), pointer`,
    cursorClick: `url('${base}/images/crafting-table.png'), pointer`
  }}>
  main {
    margin-left: var(--sidebar-width);
    padding: 4rem;
    padding-right: 20rem;
    padding-left: 20rem;
    min-height: 100vh;
    background-repeat: repeat;
    background-size: 500px 500px;
  }

  body {
    cursor: var(--cursorNormal);
  }

  :global(a), :global(button) {
    cursor: var(--cursorHover);
  }

  :global(a:active), :global(button:active) {
    cursor: var(--cursorClick);
  }
</style>
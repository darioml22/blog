---

import BaseLayout from "../layouts/BaseLayout.astro"; 
import { COLLECTIBLES, ALL_IDS } from "../lib/collectibles.js";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Mi colección">
  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
    rel="stylesheet"
  />

  <section class="pvz-page">
    <header class="pvz-header">
      <h1 class="pvz-title">Bullshit Page</h1>

      <div class="pvz-counter" aria-label="progreso de la colección">
        <span id="pvz-counter-current" class="pvz-counter-digits">000</span>
        <span class="pvz-counter-slash">/</span>
        <span class="pvz-counter-digits">{String(COLLECTIBLES.length).padStart(3, "0")}</span>
        <span class="pvz-counter-label">encontrados</span>
      </div>
    </header>

    <div class="pvz-album" id="pvz-album">
      {
        COLLECTIBLES.map((item) => (
          <div class="pvz-slot" data-slot-id={item.id}>
            <img
              class="pvz-slot-img pvz-silhouette"
              src={item.image}
              alt="figura sin descubrir"
              data-role="silhouette"
            />
            <img
              class="pvz-slot-img pvz-revealed"
              src={item.image}
              alt={item.name}
              data-role="revealed"
              hidden
            />
            <span class="pvz-slot-name" data-role="name" hidden>
              {item.name}
            </span>
            <span class="pvz-slot-question" data-role="question">?</span>
          </div>
        ))
      }
    </div>

    <div id="pvz-game-wrap" class="pvz-game-wrap" hidden>
      <div class="pvz-game-hud">
        <div class="pvz-hud-item">☀️ Sol: <span id="pvz-sun">200</span></div>
        <div class="pvz-hud-item">💀 Bajas: <span id="pvz-kills">0</span></div>
        <div class="pvz-hud-item">🎯 Objetivo: 15</div>
        <button id="pvz-restart" class="pvz-btn">Reiniciar partida</button>
      </div>
      <canvas id="pvz-canvas" width="810" height="450"></canvas>
      <p class="pvz-hint">
        Click en una casilla vacía para plantar (cuesta 100 de sol). Cada
        planta dispara sola a los zombies que entren en su fila.
      </p>
      <div id="pvz-overlay" class="pvz-overlay" hidden>
        <div class="pvz-overlay-card">
          <p id="pvz-overlay-text">—</p>
          <button id="pvz-overlay-btn" class="pvz-btn">Jugar de nuevo</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .pvz-page {
    --sky: #6fb7e8;
    --sky-deep: #3e7cb1;
    --lawn: #8bc34a;
    --lawn-deep: #5c9a2c;
    --wood: #8b5a2b;
    --wood-deep: #6b4423;
    --sun: #ffd23f;
    --ink: #2f2a1d;
    --cherry: #e63946;

    max-width: 900px;
    margin: 0 auto;
    padding: 32px 20px 64px;
    font-family: "Trebuchet MS", Verdana, sans-serif;
    color: var(--ink);
  }

  .pvz-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 4px dashed var(--wood-deep);
    padding-bottom: 16px;
    margin-bottom: 16px;
  }

  .pvz-title {
    font-family: "Press Start 2P", monospace;
    font-size: 20px;
    color: var(--wood-deep);
    text-shadow: 2px 2px 0 var(--sun);
    margin: 0;
  }

  /* El "contador de visitas" ochentero/noventero, aquí como contador de figuras */
  .pvz-counter {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #111;
    border: 3px solid var(--wood-deep);
    border-radius: 4px;
    padding: 6px 10px;
    box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.8);
  }

  .pvz-counter-digits {
    font-family: "Press Start 2P", monospace;
    font-size: 14px;
    color: #4dff4d;
    text-shadow: 0 0 6px #4dff4d;
    letter-spacing: 2px;
  }

  .pvz-counter-slash {
    color: #4dff4d;
    opacity: 0.6;
  }

  .pvz-counter-label {
    font-family: "Trebuchet MS", Verdana, sans-serif;
    font-size: 11px;
    color: #9fd89f;
    margin-left: 6px;
  }

  .pvz-hint {
    font-size: 14px;
    line-height: 1.5;
    color: #4a4535;
  }

  .pvz-album {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 14px;
    margin: 24px 0;
    padding: 18px;
    background: repeating-linear-gradient(
      45deg,
      #f4ecd8,
      #f4ecd8 10px,
      #eee2c4 10px,
      #eee2c4 20px
    );
    border: 6px solid var(--wood);
    border-radius: 10px;
  }

  .pvz-slot {
    position: relative;
    aspect-ratio: 1;
    background: #fffdf5;
    border: 3px dashed var(--wood-deep);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .pvz-slot-img {
    width: 78%;
    height: 78%;
    object-fit: contain;
  }

  .pvz-silhouette {
    filter: brightness(0);
    opacity: 0.75;
  }

  .pvz-slot-question {
    position: absolute;
    font-family: "Press Start 2P", monospace;
    font-size: 22px;
    color: rgba(0, 0, 0, 0.35);
  }

  .pvz-slot-name {
    position: absolute;
    bottom: 4px;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 10px;
    font-weight: bold;
    background: rgba(255, 255, 255, 0.85);
  }

  .pvz-slot.pvz-found .pvz-silhouette,
  .pvz-slot.pvz-found .pvz-slot-question {
    display: none;
  }
  .pvz-slot.pvz-found .pvz-revealed,
  .pvz-slot.pvz-found .pvz-slot-name {
    display: block;
  }
  .pvz-slot.pvz-found {
    border-style: solid;
    border-color: var(--lawn-deep);
    background: #f2ffe8;
  }

  .pvz-game-wrap {
    background: linear-gradient(var(--sky), var(--sky-deep) 40%);
    border: 6px solid var(--wood);
    border-radius: 10px;
    padding: 16px;
  }

  .pvz-game-hud {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    font-family: "Press Start 2P", monospace;
    font-size: 11px;
    color: var(--ink);
    background: #fffdf5;
    border: 3px solid var(--wood-deep);
    border-radius: 6px;
    padding: 10px;
    margin-bottom: 10px;
  }

  .pvz-btn {
    font-family: "Press Start 2P", monospace;
    font-size: 10px;
    background: var(--sun);
    border: 3px solid var(--wood-deep);
    border-radius: 6px;
    padding: 8px 12px;
    cursor: pointer;
    box-shadow: 0 4px 0 var(--wood-deep);
  }
  .pvz-btn:active {
    box-shadow: 0 1px 0 var(--wood-deep);
    transform: translateY(3px);
  }

  #pvz-canvas {
    display: block;
    width: 100%;
    height: auto;
    background: repeating-linear-gradient(
      var(--lawn),
      var(--lawn) 45px,
      var(--lawn-deep) 45px,
      var(--lawn-deep) 90px
    );
    border: 4px solid var(--wood-deep);
    border-radius: 6px;
    cursor: crosshair;
  }

  .pvz-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pvz-overlay-card {
    background: #fffdf5;
    border: 4px solid var(--wood-deep);
    border-radius: 10px;
    padding: 24px;
    text-align: center;
    font-family: "Press Start 2P", monospace;
    font-size: 12px;
    max-width: 320px;
  }

  .pvz-game-wrap {
    position: relative;
  }
</style>

<script>
  import { COLLECTIBLES, ALL_IDS } from "../lib/collectibles.js";
  import { getCollected, hasAll } from "../lib/storage.js";

  function renderAlbum() {
    const collected = new Set(getCollected());

    document.querySelectorAll<HTMLDivElement>(".pvz-slot").forEach((slot) => {
      const id = slot.dataset.slotId;
      if (id && collected.has(id)) {
        slot.classList.add("pvz-found");
      }
    });

    const counterEl = document.getElementById("pvz-counter-current");
    if (counterEl) {
      counterEl.textContent = String(collected.size).padStart(3, "0");
    }

    const locked = document.getElementById("pvz-locked");
    const gameWrap = document.getElementById("pvz-game-wrap");

    if (hasAll(ALL_IDS)) {
      locked?.setAttribute("hidden", "");
      gameWrap?.removeAttribute("hidden");
      initGameOnce();
    } else {
      gameWrap?.setAttribute("hidden", "");
      locked?.removeAttribute("hidden");
    }
  }

  // --- Minijuego tipo tower-defense muy simplificado ---
  let gameInitialized = false;

  function initGameOnce() {
    if (gameInitialized) return;
    gameInitialized = true;

    const canvas = document.getElementById("pvz-canvas") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d")!;
    const cols = 9;
    const rows = 5;
    const cellW = canvas.width / cols;
    const cellH = canvas.height / rows;

    const sunEl = document.getElementById("pvz-sun")!;
    const killsEl = document.getElementById("pvz-kills")!;
    const overlay = document.getElementById("pvz-overlay")!;
    const overlayText = document.getElementById("pvz-overlay-text")!;
    const overlayBtn = document.getElementById("pvz-overlay-btn")!;
    const restartBtn = document.getElementById("pvz-restart")!;

    const PLANT_COST = 100;
    const KILL_TARGET = 15;

    type Plant = { row: number; col: number; lastShot: number };
    type Zombie = { row: number; x: number; hp: number; speed: number };
    type Bullet = { row: number; x: number };

    let sun = 200;
    let kills = 0;
    let plants: Plant[] = [];
    let zombies: Zombie[] = [];
    let bullets: Bullet[] = [];
    let running = true;
    let rafId = 0;
    let spawnTimer: number;
    let sunTimer: number;

    function resetState() {
      sun = 200;
      kills = 0;
      plants = [];
      zombies = [];
      bullets = [];
      running = true;
      sunEl.textContent = String(sun);
      killsEl.textContent = String(kills);
      overlay.setAttribute("hidden", "");
      clearInterval(spawnTimer);
      clearInterval(sunTimer);
      spawnTimer = window.setInterval(spawnZombie, 3200);
      sunTimer = window.setInterval(() => {
        sun += 25;
        sunEl.textContent = String(sun);
      }, 6000);
    }

    function spawnZombie() {
      if (!running) return;
      const row = Math.floor(Math.random() * rows);
      zombies.push({ row, x: canvas.width, hp: 100, speed: 0.35 });
    }

    canvas.addEventListener("click", (e) => {
      if (!running) return;
      const rect = canvas.getBoundingClientRect();
      const scaleX = canvas.width / rect.width;
      const scaleY = canvas.height / rect.height;
      const x = (e.clientX - rect.left) * scaleX;
      const y = (e.clientY - rect.top) * scaleY;
      const col = Math.floor(x / cellW);
      const row = Math.floor(y / cellH);

      const occupied = plants.some((p) => p.row === row && p.col === col);
      if (occupied || sun < PLANT_COST) return;

      plants.push({ row, col, lastShot: 0 });
      sun -= PLANT_COST;
      sunEl.textContent = String(sun);
    });

    function endGame(won: boolean) {
      running = false;
      clearInterval(spawnTimer);
      clearInterval(sunTimer);
      overlayText.textContent = won
        ? "¡Victoria! Defendiste el jardín 🌻"
        : "¡Los zombies llegaron a la casa! 💀";
      overlay.removeAttribute("hidden");
    }

    function update() {
      const now = performance.now();

      // disparos
      plants.forEach((p) => {
        const plantX = p.col * cellW + cellW / 2;
        const target = zombies.find(
          (z) => z.row === p.row && z.x > plantX
        );
        if (target && now - p.lastShot > 1400) {
          bullets.push({ row: p.row, x: plantX });
          p.lastShot = now;
        }
      });

      // balas
      bullets = bullets.filter((b) => {
        b.x += 6;
        const hit = zombies.find(
          (z) => z.row === b.row && Math.abs(z.x - b.x) < 16
        );
        if (hit) {
          hit.hp -= 34;
          return false;
        }
        return b.x < canvas.width;
      });

      // zombies
      zombies = zombies.filter((z) => {
        z.x -= z.speed;
        if (z.hp <= 0) {
          kills++;
          killsEl.textContent = String(kills);
          if (kills >= KILL_TARGET) endGame(true);
          return false;
        }
        if (z.x < 0) {
          endGame(false);
          return false;
        }
        return true;
      });
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      // filas de césped ya vienen del CSS de fondo del canvas,
      // aquí solo dibujamos entidades encima.

      // plantas
      plants.forEach((p) => {
        const cx = p.col * cellW + cellW / 2;
        const cy = p.row * cellH + cellH / 2;
        ctx.beginPath();
        ctx.arc(cx, cy, cellH * 0.32, 0, Math.PI * 2);
        ctx.fillStyle = "#3f8f3f";
        ctx.fill();
        ctx.strokeStyle = "#295c29";
        ctx.lineWidth = 3;
        ctx.stroke();
        ctx.fillStyle = "#eaffea";
        ctx.font = "bold 14px sans-serif";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.fillText("P", cx, cy);
      });

      // balas
      bullets.forEach((b) => {
        const cy = b.row * cellH + cellH / 2;
        ctx.beginPath();
        ctx.arc(b.x, cy, 6, 0, Math.PI * 2);
        ctx.fillStyle = "#9acd32";
        ctx.fill();
      });

      // zombies
      zombies.forEach((z) => {
        const cy = z.row * cellH + cellH / 2;
        ctx.fillStyle = "#6b6b6b";
        ctx.fillRect(z.x - 18, cy - 22, 36, 44);
        ctx.strokeStyle = "#333";
        ctx.lineWidth = 2;
        ctx.strokeRect(z.x - 18, cy - 22, 36, 44);
        ctx.fillStyle = "#fff";
        ctx.font = "bold 14px sans-serif";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        ctx.fillText("Z", z.x, cy);

        // barra de vida
        ctx.fillStyle = "#222";
        ctx.fillRect(z.x - 18, cy - 30, 36, 5);
        ctx.fillStyle = "#e63946";
        ctx.fillRect(z.x - 18, cy - 30, 36 * (z.hp / 100), 5);
      });
    }

    function loop() {
      if (running) {
        update();
        draw();
      }
      rafId = requestAnimationFrame(loop);
    }

    overlayBtn.addEventListener("click", () => {
      resetState();
    });
    restartBtn.addEventListener("click", () => {
      resetState();
    });

    resetState();
    loop();
  }

  document.addEventListener("astro:page-load", renderAlbum);
  renderAlbum();
</script>